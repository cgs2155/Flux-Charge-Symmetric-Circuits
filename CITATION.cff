    given-names: C.
  - family-names: Cocquyt
    given-names: S.
  - family-names: Osborne
    given-names: A.
  - family-names: Houck
    given-names: A. A.
keywords:
  - superconducting circuits
  - circuit quantization
  - Hamiltonian
  - gyrator
  - Josephson junction
  - quantum phase slip
